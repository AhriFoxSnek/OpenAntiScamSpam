from pathlib import Path
from datetime import timedelta
import re
import os
import io
import json
import time

# 3rd party
import disnake
from disnake.ext import commands
from disnake import Forbidden
import tldextract
from PIL import Image
import imagehash


dict config
with open('config.json', 'r') as f
    config = json.loads(f.read())


const str  textmatch_backend      = config['textmatch_backend']
const str  likely___Punishment    = config['likely___Punishment']
const str  dangerousPunishment    = config['dangerousPunishment']
const bool deleteLikelyMessage    = config['deleteLikelyMessage']
const bool deleteDangerousMessage = config['deleteDangerousMessage']
const set  debugUsers             = config['debugUsers'] into set
const int  tooManyChannelsSpammed = config['tooManyChannelsSpammed']
const int  stopPayingAttentionToUserAfterThisAmountOfSeconds = config['stopPayingAttentionToUserAfterThisAmountOfSeconds']


$ def error = "Invalid value in config.\n"
if  textmatch_backend not in {'tfidf','fuzz'}
    $error+"Possible values for textmatch_backend are: tfidf, fuzz"
if likely___Punishment not in {'nothing','warn', 'mute', 'kick', 'ban'}
    $error+"Possible values for likely___Punishment are: nothing, warn, mute, kick, ban"
if dangerousPunishment not in {'nothing','warn', 'mute', 'kick', 'ban'}
    $error+"Possible values for dangerousPunishment are: nothing, warn, mute, kick, ban"
if not isinstance(   deleteLikelyMessage, bool)
    $error+"Possible values for deleteLikelyMessage are: true, false"
if not isinstance(deleteDangerousMessage, bool)
    $error+"Possible values for deleteDangerousMessage are: true, false"
if not isinstance(tooManyChannelsSpammed, int)
    $error+"Possible values for tooManyChannelsSpammed are: any integer"
if not isinstance(stopPayingAttentionToUserAfterThisAmountOfSeconds, int)
    $error+"Possible values for stopPayingAttentionToUserAfterThisAmountOfSeconds are: any integer"



if textmatch_backend "tfidf"
    from sklearn.feature_extraction.text import TfidfVectorizer
    from sklearn.metrics.pairwise import cosine_similarity
else
    from rapidfuzz import process, fuzz
    from rapidfuzz.distance import JaroWinkler

intents = disnake.Intents.default()
intents.message_content = True
intents.messages = True
intents.guilds = True

const int amount_of_detections = int(open("amount_of_detections.txt",'r').read())

RETelegramUsername = re.compile(r"@[a-zA-z0-9_.]{5,}")
REDiscordLink  = re.compile(r"(?:https?:\/\/)?(?:(?:(?:discord)?\.?gg)|(?:discordapp\.com(?:\/|\\)invite))\/[0-9a-zA-Z]{7,}")
REPhoneNumber  = re.compile(r"(?:(?:\+\d{1,2}\s*)|\s)\(?(?:\d[ \t_]*){3}\)?[\-‑]?\s*(?:\d[ \t_]*){3}[\-‑]? *(?:\d[ \t_]*){4}\s")
RETelegramLink = re.compile(r"(?:https?:\/\/)?t.me\/.+")
REDollarAmount = re.compile(r"\$(?:[1-9]\d{0,3}?,)?\d+(?:\.\d)?[kK]?\+?")
const tuple RECompiles = (
        (RETelegramUsername, '@SuspiciousUsername'),
        (REDiscordLink,      'discord.gg/1A2b3cD4'),
        (REPhoneNumber,      '555-123-456'),
        (RETelegramLink,     't.me/suspiciousLink'),
        (REDollarAmount,     '-$9999K')
   )
const set bannedLinks
with open('banned_domains.txt', 'r') as f
    bannedLinks = set(f.read().split('\n'))
    # got most of the links from:
    # https://github.com/TermuxHackz/scam-links

const str SUS_LLM_CHARACTERS = "—◦–“’”→…"


applyRegexToString does str
    loop RECompiles regex
        theMsg = re.sub(regex[0], regex[1], theMsg)
    return theMsg
from str theMsg

  set[str] badInvites = set()
tuple[str] badStrings = ()
tuple      badImages  = ()


"Loading banned messages ... "
with open('banned_messages.txt', 'r', encoding='utf-8') as f
    badStrings = tuple([text to applyRegexToString for text in f.read().split('\n== next scam spam ==\n')])
with open('banned_invites.txt',  'r', encoding='utf-8') as f
    badInvites = f.read().split('\n') into set
"Hashing banned images ..."
for s in os.listdir(Path.cwd() / "banned_images")
    with Image.open(Path.cwd() / 'banned_images'  / s, 'r') as f
        badImages  = badImages + (imagehash.phash(f),)



dict payAttentionToUserTimeout = {}
dict[list[int]] channelsUserHasMessaged = {}



if textmatch_backend "tfidf"
    # TF-IDF matrix
    vectorizer = TfidfVectorizer(
                        analyzer='word',
                        ngram_range=(1, 2),
                        min_df=1,
                        strip_accents='unicode',
                        lowercase=True
                  )
    corpus_matrix = vectorizer.fit_transform(badStrings)


def scanTFIDF(theMessage: str, addSus: float = 0.0) -> tuple[bool, bool]:
    float:
        const LIKELY_THRESHOLD    = 0.76
        const DANGEROUS_THRESHOLD = 0.90

    scores = cosine_similarity(vectorizer.transform([theMessage]), corpus_matrix)
    best = scores.max() + addSus
    
    print(f"tfidf_score={best:.4f} dangerous_threshold={DANGEROUS_THRESHOLD} likely_threshold={LIKELY_THRESHOLD}")
    if   best >= DANGEROUS_THRESHOLD then return (True,  True)   # dangerous
    elif best >= LIKELY_THRESHOLD    then return (True,  False)  # likely
    else                                  return (False, False)  # safe


calcMatchRatio does float
    return ((len(userString) / 2000) ** 1.5) * 0.25
from str userString

scanImageHashes does tuple[bool, bool]
    loop badImages NewHash
        if OGHash - NewHash < 5
            if debug then print f"imageHash = {OGHash - NewHash}"
            if OGHash - NewHash == 0
                return (True, True) # dangerous
            return (True, False) # likely
    return (False, False) # safe
from OGHash, bool debug = True




async scanMessage does bool
    # True  = unsafe
    # False = safe
    const str theMessage = message.content
    float theMatch = None
    bool detected False
    float sus = 0.0
    
    # if there is no text, no need to scan the text of the message
    if theMessage
         # small signals that make a message sus
        if theMessage[:2] is '# '    then sus += 0.1 # makes message huge
        if '@everyone' in theMessage then sus += 0.1 # spammers like everyones attention
        loop SUS_LLM_CHARACTERS c # likely LLM generated message
            if c in theMessage       then sus += 0.05 
        
        # bad invite in message
        for link in re.findall(REDiscordLink, theMessage)
            if link.split('/')[-1] in badInvites
                detected True ; break
        
        
        theMessage = theMessage to applyRegexToString # anonymize for better matches
        
        # bad link in message
        detected = any(
            f"{ext.domain}.{ext.suffix}" in bannedLinks
            for ext in map(tldextract.extract, theMessage.split())
        )
        
        # matching a text
        if textmatch_backend 'fuzz'
            theMatch = process.extractOne(theMessage, badStrings, scorer=JaroWinkler.distance)[1] - sus
            if not detected and theMatch <= calcMatchRatio(theMessage) then detected True
        else
            result = scanTFIDF(theMessage, sus)
            if result[0] then return result
        
    # image scan
    if not detected and message.attachments
        for attachment in message.attachments
            if attachment.filename.split('.')[-1] in {'png','jpg','jpeg','webp'}
                theImage = await attachment.to_file()
                theImage = pipe theImage.fp.read()   \
                           to io.BytesIO             \
                           to Image.open             \
                           to imagehash.phash        \
                           to scanImageHashes
                if theImage[0] then return theImage
        
    if detected
        if textmatch_backend 'fuzz'
            print f"matchRatio={theMatch[1]} unsafeRatioRequirement={calcMatchRatio(theMessage)}"
            if theMatch <= 0.0 then return True, True # dangerous
        return True, False # unlikely
    return False, False # safe
from message


bot = commands.Bot(command_prefix='oASS!', intents=intents, activity=disnake.CustomActivity(name=f"{amount_of_detections} scams stopped!"))

@bot.event
async def on_ready():
    f"Logged in as {bot.user}"
    "------"

@bot.event
async def on_message(message: disnake.Message):
    global amount_of_detections
    # Ignore messages from the bot itself to prevent loops
    if message.author is bot.user or message.author.bot then return
    
    $ inline userID = message.author.id
    safety = await scanMessage(message)
    if safety[0]:
        str dangerTypeStr = 'Dangerous' if safety[1] else 'Likely'
        print f"{dangerTypeStr} match found!"
        print f"{message.author} {message.author.id}"
        print "______"
        print message.content
        print "______"
        
        if $userID in channelsUserHasMessaged \
        and message.channel not in channelsUserHasMessaged[$userID] \
        and payAttentionToUserTimeout[$userID][1] >= tooManyChannelsSpammed \
            # user has spammed a bunch, theyre probably dangerous
            safety = (True, True) ; print "\tThey are such a spammer ... "
        
        str doThisPunishment = likely___Punishment
        if safety[1]
            doThisPunishment = dangerousPunishment
        if $userID in debugUsers
            doThisPunishment = 'warn'
            
        if deleteLikelyMessage or (safety[1] and deleteDangerousMessage)
            try await message.delete()
            except Exception as e
                print f"could not delete message: {e}"
         
        
        str warnyMessage = f"# {message.author.nick+' /' if message.author.nick else ''} `{message.author.name}` is a {dangerTypeStr.lower()} scam spammer!\n{'-# or this is a false positive and I made a mistake... Use your judgement cautiously!' if not safety[1] else ''}\n"
        $ def sendWarnMessage = await message.channel.send(warnyMessage+
        
        match doThisPunishment
        of 'nothing' do nothing
        of 'warn'    do $sendWarnMessage "Please do not fall for their evil lies! Alert this guild's moderators, and report to discord.")
        of 'mute'
            try
                await message.author.timeout(duration=timedelta(28), reason=f"oASS detection: {dangerTypeStr} scam spammer!")
                $sendWarnMessage "They were muted for 28 days.")
            except Forbidden
                $sendWarnMessage "I am missing permission to mute.")
        of 'kick'
            try
                await message.author.kick(reason=f"oASS detection: {dangerTypeStr} scam spammer!")
                $sendWarnMessage "They were kicked.")
            except Forbidden
                $sendWarnMessage "I am missing permission to kick.")
        of 'ban'
            try
                await message.author.ban(delete_message_days=7 ,reason=f"oASS detection: {dangerTypeStr} scam spammer!")
                $sendWarnMessage "They were banned.")
            except Forbidden
                $sendWarnMessage "I am missing permission to ban.")
        
        if $userID not in debugUsers  
            with open("amount_of_detections.txt",'w') as f
                ++amount_of_detections to str to f.write
    
    if $userID not in channelsUserHasMessaged
        payAttentionToUserTimeout[$userID]   = [time.monotonic() + stopPayingAttentionToUserAfterThisAmountOfSeconds, 1]
        channelsUserHasMessaged[$userID]     = [message.channel]
    else
        if message.channel not in channelsUserHasMessaged[$userID]
            channelsUserHasMessaged[$userID].append(message.channel)
            payAttentionToUserTimeout[$userID][1] += 1
        if time.monotonic() >= payAttentionToUserTimeout[$userID][0]
            del payAttentionToUserTimeout[$userID]
            del channelsUserHasMessaged[$userID]
        
            
    await bot.process_commands(message)

from dotenv import load_dotenv ; load_dotenv()
bot.run(os.getenv('DISCORD_BOT_TOKEN'))
